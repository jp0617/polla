generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String       @unique
  passwordHash String
  totalPoints  Int          @default(0)
  manualPoints Int          @default(0)
  isAdmin      Boolean      @default(false)
  predictions  Prediction[]
  memberships  Membership[]
  adminOfCodes InvitationCode[] @relation("CodeAdmin")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([totalPoints])
}

model Membership {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitationCodeId String
  invitationCode   InvitationCode @relation("CodeMembership", fields: [invitationCodeId], references: [id], onDelete: Cascade)
  favoriteTeamId   String?
  favoriteTeam     Team?          @relation("MemberFavoriteTeam", fields: [favoriteTeamId], references: [id])
  championPickId   String?
  championPick     Team?          @relation("MemberChampionPick", fields: [championPickId], references: [id])
  bonusPoints      Int            @default(0)
  joinedAt         DateTime       @default(now())

  @@unique([userId, invitationCodeId])
  @@index([invitationCodeId])
}

model InvitationCode {
  id          String       @id @default(cuid())
  code        String       @unique
  label       String?
  maxUses     Int          @default(1)
  uses        Int          @default(0)
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  memberships Membership[] @relation("CodeMembership")
  adminId     String?
  admin       User?        @relation("CodeAdmin", fields: [adminId], references: [id])
}

model Team {
  id                  String         @id @default(cuid())
  apiId               Int            @unique
  name                String
  shortName           String
  code                String
  crest               String?
  group               String?
  currentStage        String         @default("GROUP_STAGE")
  eliminated          Boolean        @default(false)
  homeMatches         Match[]        @relation("HomeTeam")
  awayMatches         Match[]        @relation("AwayTeam")
  memberFavorites     Membership[]   @relation("MemberFavoriteTeam")
  memberChampionPicks Membership[]   @relation("MemberChampionPick")
  phaseAdvances       PhaseAdvance[]
}

model Match {
  id          String       @id @default(cuid())
  apiMatchId  Int          @unique
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff     DateTime
  stage       String
  group       String?
  status      MatchStatus  @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  predictions Prediction[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([kickoff])
  @@index([status])
}

model Prediction {
  id        String           @id @default(cuid())
  userId    String
  matchId   String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore Int
  awayScore Int
  points    Int?
  status    PredictionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model PhaseAdvance {
  id         String   @id @default(cuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  fromStage  String
  toStage    String
  detectedAt DateTime @default(now())
  bonusGiven Boolean  @default(false)
}

model ScoringConfig {
  id                 String   @id @default("singleton")
  exactScore         Int      @default(5)
  correctWinner      Int      @default(3)
  correctDraw        Int      @default(2)
  bonusPhaseAdvance  Int      @default(2)
  championBonus      Int      @default(10)
  lockMinutes        Int      @default(5)
  championTeamId     String?
  championBonusGiven Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

enum MatchStatus {
  SCHEDULED
  IN_PLAY
  PAUSED
  FINISHED
  POSTPONED
  CANCELLED
}

enum PredictionStatus {
  PENDING
  LOCKED
  SCORED
}
